    "morgan": "^1.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "jest": "^30.2.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.4.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
